// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"

  
  
}

model User {
  id            String    @id @default(cuid())
  isAdmin       Boolean   @default(false)
  role          Role      @default(BASIC)
  email         String    @unique
  emailVerified Boolean  @default(false)
  name          String?
  age           Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tests         Test[]    @relation("ActiveTests")
  sessions      Session[]
  accounts      Account[]

  @@index([email])
}

model Test {
  id         String     @id @default(cuid())
  name       String
  testCode   String?    @unique
  testedDay  DateTime   @default(now())
  status     TestStatus @default(UPCOMING)
  location   String?
  resultUrl  String?
  resultName String?
  uploadedAt DateTime?
  walkinName String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @default(now()) @updatedAt

  patient   User?   @relation("ActiveTests", fields: [patientId], references: [id])
  patientId String?
}

model Order {
  id        String   @id @default(cuid())
  name      String
  phone     String
  branch    String
  listType  String
  express   Boolean  @default(false)
  total     Int
  count     Int
  pdfUrl    String
  createdAt DateTime @default(now())
}


enum TestStatus {
  UPCOMING
  CURRENT
  PAST
}

enum Role {
  BASIC
  ADMIN
  OWNER
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
